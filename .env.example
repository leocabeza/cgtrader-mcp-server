# OAuth client_credentials — register an app at https://www.cgtrader.com/oauth/applications/new
CGTRADER_CLIENT_ID=your-client-id
CGTRADER_CLIENT_SECRET=your-client-secret

# Optional: override the OAuth token endpoint if CGTrader's lives elsewhere
# CGTRADER_OAUTH_TOKEN_URL=https://www.cgtrader.com/oauth/token

# Optional: request a specific OAuth scope
# CGTRADER_OAUTH_SCOPE=public

# HTTP server bind
PORT=3000
HOST=127.0.0.1
